{
  "name": "ggbview",
  "displayName": "ggbview",
  "description": "GeoGebra文件查看器插件",
  "publisher": "neon-light",
  "icon": "media/ggb-icon.png",
  "version": "0.0.8",
  "engines": {
    "vscode": "^1.75.1"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shasky2014/vscode-ggbview.git"
  },
  "license": "MIT",
  "activationEvents": [
    "onCustomEditor:ggbview.ggbView",
    "onCommand:ggbview.open"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "ggbview",
      "properties": {
        "ggbview.default.showToolBar": {
          "markdownDescription": "set your ggb editor show Tool Bar or not.",
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ]},
        "ggbview.default.showMenuBar": {
          "markdownDescription": "set your ggb editor show Tool Bar or not.",
          "type": "boolean",
          "default": false,
          "enum": [
            false,
            true
          ]},
          "ggbview.default.showAlgebraInput": {
            "markdownDescription": "set your ggb editor show Algebra Input or not.",
            "type": "boolean",
            "default": false,
            "enum": [
              false,
              true
            ]},
            "ggbview.default.allowStyleBar": {
              "markdownDescription": "set your ggb editor allow Style Bar or not.",
              "type": "boolean",
              "default": false,
              "enum": [
                false,
                true
              ]},
              "ggbview.default.showToolBarHelp": {
                "markdownDescription": "set your ggb editor showToolBarHelp or not.",
                "type": "boolean",
                "default": false,
                "enum": [
                  false,
                  true
                ]}
              
      }
    },
    "customEditors": [
      {
        "viewType": "ggbview.ggbView",
        "displayName": "GeoGebra View",
        "selector": [
          {
            "filenamePattern": "*.ggb"
          },
          {
            "filenamePattern": "*.ggt"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ggbview.open",
        "title": "GGB:Open File",
        "arguments": [
          "${file}"
        ]
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.x",
    "@types/vscode": "^1.75.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2"
  },
  "dependencies": {
    "eslint": "^9.39.2"
  }
}
